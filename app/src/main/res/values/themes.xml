<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AlarmaCiclosCircadianos" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Tipografía global -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Circadian.Headline</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Circadian.Headline</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Circadian.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Circadian.Display</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Circadian.Display</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Circadian.Body</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Circadian.Body</item>
    </style>

    <style name="TextAppearance.Circadian" parent="@style/TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="android:fontFamily">@font/space_grotesk</item>
    </style>

    <style name="TextAppearance.Circadian.Display" parent="@style/TextAppearance.Circadian">
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="android:fontFamily">@font/space_grotesk</item>
    </style>

    <style name="TextAppearance.Circadian.Headline" parent="@style/TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="android:fontFamily">@font/space_grotesk</item>
    </style>

    <style name="TextAppearance.Circadian.Body" parent="@style/TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/ibm_plex_sans</item>
        <item name="android:fontFamily">@font/ibm_plex_sans</item>
    </style>

    <style name="Theme.AlarmaCiclosCircadianos" parent="Base.Theme.AlarmaCiclosCircadianos">
        <item name="windowActionBar">false</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>