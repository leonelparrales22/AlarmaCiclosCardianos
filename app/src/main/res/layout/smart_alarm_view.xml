<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.alarm.SmartAlarmActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/alarmScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/padding_screen_horizontal"
        android:paddingEnd="@dimen/padding_screen_horizontal"
        android:paddingTop="@dimen/padding_screen_vertical"
        android:paddingBottom="@dimen/padding_screen_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/alarmHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/alarmBackButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:padding="@dimen/spacing_section_xsmall"
                    android:contentDescription="@string/config_back"
                    android:src="@drawable/ic_arrow_left"
                    android:tint="@color/ink_900"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/alarmTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/smart_alarm_title"
                    android:textColor="@color/ink_900"
                    android:textSize="@dimen/text_size_sleep_title"
                    android:textStyle="bold"
                    android:fontFamily="@font/space_grotesk"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/alarmMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_menu_placeholder"
                    android:textColor="@color/ink_300"
                    android:textSize="@dimen/text_size_sleep_menu"
                    android:fontFamily="@font/space_grotesk"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_large"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:spacing="0dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/alarm_icon_container_size"
                    android:layout_height="@dimen/alarm_icon_container_size"
                    android:layout_marginBottom="@dimen/spacing_section_medium"
                    app:cardCornerRadius="@dimen/radius_card_medium"
                    app:strokeColor="@color/ink_200"
                    app:strokeWidth="@dimen/stroke_width_hairline"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/alarm_icon_padding"
                        android:src="@drawable/ic_alarm_clock"
                        android:contentDescription="@string/smart_alarm_title" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/alarmTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/smart_alarm_time"
                    android:textColor="@color/ink_900"
                    android:textSize="@dimen/text_size_alarm_time"
                    android:letterSpacing="-0.01"
                    android:textStyle="bold"
                    android:fontFamily="@font/space_grotesk" />

                <TextView
                    android:id="@+id/alarmSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_section_tiny"
                    android:text="@string/smart_alarm_subtitle"
                    android:textColor="@color/ink_500"
                    android:textSize="@dimen/text_size_sleep_hint"
                    android:fontFamily="@font/ibm_plex_sans" />

                <TextView
                    android:id="@+id/alarmWindowChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_section_small"
                    android:background="@drawable/bg_alarm_chip"
                    android:paddingStart="@dimen/alarm_chip_padding_horizontal"
                    android:paddingEnd="@dimen/alarm_chip_padding_horizontal"
                    android:paddingTop="@dimen/alarm_chip_padding_vertical"
                    android:paddingBottom="@dimen/alarm_chip_padding_vertical"
                    android:text="@string/smart_alarm_window_hint"
                    android:textColor="@color/ink_600"
                    android:textSize="@dimen/text_size_status_label"
                    android:fontFamily="@font/ibm_plex_sans" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/audioCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_xlarge"
                app:cardCornerRadius="@dimen/radius_card_large"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="@dimen/stroke_width_hairline"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/alarm_card_spacing">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/smart_alarm_audio_title"
                            android:textColor="@color/ink_600"
                            android:textSize="@dimen/text_size_sleep_hint"
                            android:textStyle="bold"
                            android:fontFamily="@font/ibm_plex_sans" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/smart_alarm_audio_status"
                            android:textColor="@color/ink_400"
                            android:textSize="@dimen/text_size_status_label"
                            android:fontFamily="@font/ibm_plex_sans" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_section_small"
                        app:cardCornerRadius="@dimen/alarm_wave_corner_radius"
                        app:strokeColor="@color/ink_200"
                        app:strokeWidth="@dimen/stroke_width_hairline"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/alarm_wave_height"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_alarm_waveform"
                            android:contentDescription="@string/smart_alarm_audio_title" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_section_tiny"
                        android:gravity="end"
                        android:text="@string/smart_alarm_audio_percentage"
                        android:textColor="@color/ink_400"
                        android:textSize="@dimen/text_size_status_label"
                        android:fontFamily="@font/ibm_plex_sans" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/snoozeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_medium"
                app:cardCornerRadius="@dimen/radius_card_large"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="@dimen/stroke_width_hairline"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/alarm_card_spacing">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/smart_alarm_snooze_indicator"
                            android:textColor="@color/ink_500"
                            android:textSize="@dimen/text_size_alarm_indicator"
                            android:layout_marginEnd="@dimen/spacing_section_small"
                            android:fontFamily="@font/space_grotesk" />

                        <TextView
                            android:id="@+id/snoozeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/smart_alarm_snooze_title"
                            android:textColor="@color/ink_900"
                            android:textSize="@dimen/text_size_sleep_hint"
                            android:textStyle="bold"
                            android:fontFamily="@font/ibm_plex_sans" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/snoozeDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_section_tiny"
                        android:text="@string/smart_alarm_snooze_desc"
                        android:textColor="@color/ink_500"
                        android:textSize="@dimen/text_size_status_label"
                        android:fontFamily="@font/ibm_plex_sans" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/slideToOffButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/alarm_slide_height"
                android:layout_marginTop="@dimen/spacing_section_xlarge"
                android:text="@string/smart_alarm_slide_action"
                android:textAllCaps="false"
                android:textColor="@color/ink_800"
                android:textSize="@dimen/text_size_button"
                android:backgroundTint="@color/white"
                app:strokeColor="@color/ink_300"
                app:strokeWidth="@dimen/stroke_width_hairline"
                app:cornerRadius="@dimen/radius_card_medium"
                android:fontFamily="@font/ibm_plex_sans" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
