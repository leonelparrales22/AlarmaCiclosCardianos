<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.home.HomeActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/homeDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_date_label"
                android:textAllCaps="true"
                android:letterSpacing="0.2"
                android:textColor="@color/ink_500"
                android:textSize="12sp"
                app:fontFamily="@font/ibm_plex_sans" />

            <TextView
                android:id="@+id/homeGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/home_greeting"
                android:textColor="@color/ink_900"
                android:textSize="31sp"
                android:letterSpacing="-0.02"
                android:fontFamily="@font/space_grotesk_semibold" />

            <TextView
                android:id="@+id/homeWindowLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_window_active"
                android:textColor="@color/ink_500"
                android:textSize="14sp"
                android:letterSpacing="-0.02"
                app:fontFamily="@font/ibm_plex_sans" />

            <LinearLayout
                android:id="@+id/gaugeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center">

                        <View
                            android:id="@+id/sleepQualityGauge"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:background="@drawable/bg_sleep_quality_ring" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_sleep_quality_label"
                                android:textAllCaps="true"
                                android:letterSpacing="0.2"
                                android:textSize="12sp"
                                android:textColor="@color/ink_500"
                                app:fontFamily="@font/ibm_plex_sans" />

                            <TextView
                                android:id="@+id/sleepQualityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/home_sleep_quality_value"
                                android:textColor="@color/success_accent"
                                android:textSize="48sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02"
                                android:fontFamily="@font/space_grotesk" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/windowMetChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_window_met_chip">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="@string/home_window_met_status_desc"
                            android:src="@drawable/ic_check_pill"
                            android:tint="@color/ink_900" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_window_met_label"
                                android:textColor="@color/ink_900"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:fontFamily="@font/ibm_plex_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_window_met_value"
                                android:textColor="@color/ink_500"
                                android:textSize="12sp"
                                app:fontFamily="@font/ibm_plex_sans" />
                        </LinearLayout>
                    </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/smartAlarmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="32dp"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="1dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_smart_alarm_title"
                            android:textColor="@color/ink_600"
                            android:textSize="14sp"
                            app:fontFamily="@font/ibm_plex_sans" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/smartAlarmSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:showText="false"
                            app:thumbTint="@color/switch_thumb_tint"
                            app:trackTint="@color/switch_track_tint"
                            app:useMaterialThemeColors="false" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/smartAlarmWindow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/home_alarm_window"
                        android:textColor="@color/ink_900"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        app:fontFamily="@font/space_grotesk" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_next_alarm_hint"
                        android:textColor="@color/ink_500"
                        android:textSize="13sp"
                        android:letterSpacing="-0.01"
                        app:fontFamily="@font/ibm_plex_sans" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_absolute_limit_label"
                            android:textColor="@color/ink_500"
                            android:textSize="12sp"
                            app:fontFamily="@font/ibm_plex_sans" />

                        <TextView
                            android:id="@+id/absoluteLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_absolute_limit_value"
                            android:textColor="@color/ink_700"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:fontFamily="@font/space_grotesk" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip_sky"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_status_sensor"
                                android:contentDescription="@string/home_status_sensors_label" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_status_sensors_label"
                                    android:textColor="@color/sky_500"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    app:fontFamily="@font/ibm_plex_sans" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_status_sensors_value"
                                    android:textColor="@color/ink_500"
                                    android:textSize="11sp"
                                    app:fontFamily="@font/ibm_plex_sans" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip_success"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_status_battery"
                                android:contentDescription="@string/home_status_battery_label" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_status_battery_label"
                                    android:textColor="@color/success_500"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    app:fontFamily="@font/ibm_plex_sans" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_status_battery_value"
                                    android:textColor="@color/ink_500"
                                    android:textSize="11sp"
                                    app:fontFamily="@font/ibm_plex_sans" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/configureWindowButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/home_configure_window"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/ink_900"
                android:backgroundTint="@color/white"
                app:cornerRadius="24dp"
                app:fontFamily="@font/ibm_plex_sans"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sleepModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/home_sleep_mode"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/ink_900"
                app:cornerRadius="24dp"
                app:fontFamily="@font/ibm_plex_sans" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
