<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ink_100"
    tools:context=".ui.home.HomeActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/homeDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Domingo 12 Oct"
                android:textAllCaps="true"
                android:letterSpacing="0.2"
                android:textColor="@color/ink_500"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/homeGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Buenos días"
                android:textColor="@color/ink_900"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/homeWindowLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ventana activa · 7:00 - 7:30"
                android:textColor="@color/ink_500"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/gaugeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardElevation="6dp"
                app:cardCornerRadius="32dp"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/sleepQualityGauge"
                            style="@style/Widget.MaterialComponents.CircularProgressIndicator"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:indeterminate="false"
                            android:progress="85"
                            app:indicatorColor="@color/success_500"
                            app:indicatorDirectionCircular="clockwise"
                            app:trackColor="@color/ink_200"
                            app:trackThickness="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calidad"
                                android:textAllCaps="true"
                                android:letterSpacing="0.2"
                                android:textSize="12sp"
                                android:textColor="@color/ink_500" />

                            <TextView
                                android:id="@+id/sleepQualityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="85"
                                android:textColor="@color/success_500"
                                android:textSize="42sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </FrameLayout>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/windowMetChip"
                        style="@style/Widget.MaterialComponents.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Window Met · Sí"
                        android:textColor="@color/white"
                        app:chipBackgroundColor="@color/ink_900"
                        app:chipIcon="@android:drawable/checkbox_on_background"
                        app:chipIconTint="@color/white"
                        app:chipIconVisible="true"
                        app:chipMinHeight="36dp"
                        tools:ignore="UseAppTint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/smartAlarmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="32dp"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Smart Alarm"
                            android:textColor="@color/ink_500"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/smartAlarmSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:useMaterialThemeColors="true" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/smartAlarmWindow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="7:00 - 7:30 AM"
                        android:textColor="@color/ink_900"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Próxima alarma inteligente"
                        android:textColor="@color/ink_500"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="space_between">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Límite absoluto"
                            android:textColor="@color/ink_500"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/absoluteLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7:30 AM"
                            android:textColor="@color/ink_700"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/statusChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:chipSpacing="8dp"
                        android:rowCount="2">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Assist"
                            android:text="Sensores · OK"
                            android:textColor="@color/sky_500"
                            app:chipBackgroundColor="@color/sky_100"
                            app:chipStrokeColor="@color/sky_500"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Assist"
                            android:text="Batería · 92%"
                            android:textColor="@color/success_500"
                            app:chipBackgroundColor="@color/success_100"
                            app:chipStrokeColor="@color/success_500"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Assist"
                            android:text="Ventana · 7:00-7:30"
                            android:textColor="@color/amber_400"
                            app:chipBackgroundColor="@color/amber_100"
                            app:chipStrokeColor="@color/amber_400"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Assist"
                            android:text="Window Met · Sí"
                            android:textColor="@color/ink_900"
                            app:chipBackgroundColor="@color/ink_200"
                            app:chipStrokeColor="@color/ink_900"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/configureWindowButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Configurar ventana"
                android:textAllCaps="false"
                android:textColor="@color/ink_800"
                app:strokeColor="@color/ink_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sleepModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Modo Sueño"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/ink_900" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
