<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sleep_surface"
    tools:context=".ui.sleep.SleepActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sleepScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/padding_screen_horizontal"
        android:paddingEnd="@dimen/padding_screen_horizontal"
        android:paddingTop="@dimen/padding_screen_vertical"
        android:paddingBottom="@dimen/padding_screen_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/sleepHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/sleepBackButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:padding="@dimen/spacing_section_xsmall"
                    android:contentDescription="@string/config_back"
                    android:src="@drawable/ic_arrow_left"
                    android:tint="@color/ink_900"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/sleepTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_title"
                    android:textColor="@color/ink_900"
                    android:textSize="@dimen/text_size_sleep_title"
                    android:textStyle="bold"
                    app:fontFamily="@font/space_grotesk"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/sleepMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_menu_placeholder"
                    android:textColor="@color/ink_300"
                    android:textSize="@dimen/text_size_sleep_menu"
                    app:fontFamily="@font/space_grotesk"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_xlarge"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/sleepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_time_label"
                    android:textColor="@color/ink_900"
                    android:textSize="@dimen/text_size_sleep_time"
                    android:textStyle="bold"
                    app:fontFamily="@font/space_grotesk" />

                <ImageView
                    android:layout_width="@dimen/sleep_moon_size"
                    android:layout_height="@dimen/sleep_moon_size"
                    android:layout_marginTop="@dimen/spacing_section_small"
                    android:src="@drawable/ic_sleep_moon"
                    android:contentDescription="@string/sleep_status_hint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_section_xsmall"
                    android:text="@string/sleep_status_hint"
                    android:textColor="@color/ink_500"
                    android:textSize="@dimen/text_size_sleep_hint"
                    app:fontFamily="@font/ibm_plex_sans" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/statusList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_xlarge"
                android:orientation="vertical"
                android:showDividers="none"
                android:dividerPadding="0dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_section_small"
                    android:backgroundTint="@color/white"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="false"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/ink_200"
                    app:strokeWidth="@dimen/stroke_width_hairline">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/status_card_padding_horizontal"
                        android:paddingEnd="@dimen/status_card_padding_horizontal"
                        android:paddingTop="@dimen/status_card_padding_vertical"
                        android:paddingBottom="@dimen/status_card_padding_vertical">

                        <ImageView
                            android:layout_width="@dimen/status_icon_size"
                            android:layout_height="@dimen/status_icon_size"
                            android:src="@drawable/ic_sleep_phone"
                            android:contentDescription="@string/sleep_device_phone_label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/status_label_margin_start"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_phone_label"
                                android:textColor="@color/ink_500"
                                android:textSize="@dimen/text_size_status_label"
                                app:fontFamily="@font/ibm_plex_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_phone_value"
                                android:textColor="@color/ink_900"
                                android:textSize="@dimen/text_size_status_value"
                                android:textStyle="bold"
                                app:fontFamily="@font/ibm_plex_sans" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sleep_card_menu"
                            android:textColor="@color/ink_300"
                            android:textSize="@dimen/text_size_sleep_card_menu"
                            app:fontFamily="@font/space_grotesk" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_section_small"
                    android:backgroundTint="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/ink_200"
                    app:strokeWidth="@dimen/stroke_width_hairline">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/status_card_padding_horizontal"
                        android:paddingEnd="@dimen/status_card_padding_horizontal"
                        android:paddingTop="@dimen/status_card_padding_vertical"
                        android:paddingBottom="@dimen/status_card_padding_vertical">

                        <ImageView
                            android:layout_width="@dimen/status_icon_size"
                            android:layout_height="@dimen/status_icon_size"
                            android:src="@drawable/ic_sleep_watch"
                            android:contentDescription="@string/sleep_device_watch_label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/status_label_margin_start"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_watch_label"
                                android:textColor="@color/ink_500"
                                android:textSize="@dimen/text_size_status_label"
                                app:fontFamily="@font/ibm_plex_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_watch_value"
                                android:textColor="@color/ink_900"
                                android:textSize="@dimen/text_size_status_value"
                                android:textStyle="bold"
                                app:fontFamily="@font/ibm_plex_sans" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sleep_card_menu"
                            android:textColor="@color/ink_300"
                            android:textSize="@dimen/text_size_sleep_card_menu"
                            app:fontFamily="@font/space_grotesk" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="false"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/ink_200"
                    app:strokeWidth="@dimen/stroke_width_hairline">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/status_card_padding_horizontal"
                        android:paddingEnd="@dimen/status_card_padding_horizontal"
                        android:paddingTop="@dimen/status_card_padding_vertical"
                        android:paddingBottom="@dimen/status_card_padding_vertical">

                        <ImageView
                            android:layout_width="@dimen/status_icon_size"
                            android:layout_height="@dimen/status_icon_size"
                            android:src="@drawable/ic_sleep_battery"
                            android:contentDescription="@string/sleep_device_battery_label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/status_label_margin_start"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_battery_label"
                                android:textColor="@color/ink_500"
                                android:textSize="@dimen/text_size_status_label"
                                app:fontFamily="@font/ibm_plex_sans" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sleep_device_battery_value"
                                android:textColor="@color/ink_900"
                                android:textSize="@dimen/text_size_status_value"
                                android:textStyle="bold"
                                app:fontFamily="@font/ibm_plex_sans" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sleep_card_menu"
                            android:textColor="@color/ink_300"
                            android:textSize="@dimen/text_size_sleep_card_menu"
                            app:fontFamily="@font/space_grotesk" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_section_large"
                android:background="@drawable/bg_sleep_warning"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/warning_icon_size"
                    android:layout_height="@dimen/warning_icon_size"
                    android:src="@drawable/ic_sleep_warning"
                    android:contentDescription="@string/sleep_warning_message" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_section_small"
                    android:layout_weight="1"
                    android:text="@string/sleep_warning_message"
                    android:textColor="@color/ink_700"
                    android:textSize="@dimen/text_size_warning_message"
                    app:fontFamily="@font/ibm_plex_sans" />

                <TextView
                    android:id="@+id/reviewPermissions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_warning_action"
                    android:textColor="@color/sky_600"
                    android:textSize="@dimen/text_size_warning_action"
                    android:textStyle="bold"
                    app:fontFamily="@font/ibm_plex_sans" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pauseButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:layout_marginTop="@dimen/spacing_section_xlarge"
                android:text="@string/sleep_pause_button"
                android:textAllCaps="false"
                android:textColor="@color/ink_700"
                android:textSize="@dimen/text_size_button"
                android:backgroundTint="@color/ink_100"
                app:strokeColor="@color/ink_200"
                app:strokeWidth="@dimen/stroke_width_hairline"
                app:cornerRadius="@dimen/radius_button"
                app:fontFamily="@font/ibm_plex_sans" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wakeNowButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:layout_marginTop="@dimen/spacing_section_small"
                android:text="@string/sleep_wake_now_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_button"
                android:backgroundTint="@color/ink_900"
                app:cornerRadius="@dimen/radius_button"
                app:fontFamily="@font/ibm_plex_sans" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
